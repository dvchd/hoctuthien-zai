// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  ADMIN
  MENTOR
  MENTEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  PENDING_ACTIVATION  // Chờ kích hoạt (chuyển khoản 10k)
}

enum SessionStatus {
  PENDING_PAYMENT   // Chờ thanh toán
  SCHEDULED         // Đã lên lịch
  COMPLETED         // Hoàn thành
  CANCELLED         // Đã hủy
  NO_SHOW           // Không tham gia
}

enum TransactionType {
  ACTIVATION        // Kích hoạt tài khoản
  SESSION_PAYMENT   // Thanh toán buổi học
  DONATION          // Quyên góp
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ==================== USER ====================

model User {
  id String @id @default(cuid())

  // Authentication
  email        String  @unique
  googleId     String? @unique
  name         String?
  avatarUrl    String?
  phone        String?

  // Role & Status
  role       UserRole   @default(MENTEE)
  status     UserStatus @default(PENDING_ACTIVATION)

  // Activation
  activationCode    String?   @unique // Mã kích hoạt (VD: ABCXYZ)
  activationCodeExpiry DateTime?
  isActivated       Boolean   @default(false)
  activatedAt       DateTime?

  // Profile Info
  bio        String?
  skills     String?   // JSON string for skills array

  // Audit Fields
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  createdBy  String?
  updatedBy  String?

  // Soft Delete
  isDeleted  Boolean    @default(false)
  deletedAt  DateTime?
  deletedBy  String?

  // Versioning
  version    Int        @default(0)

  // Relations
  mentorProfile      MentorProfile?
  menteeProfile      MenteeProfile?
  mentorSessions     SessionMentoring[] @relation("MentorSessions")
  menteeSessions     SessionMentoring[] @relation("MenteeSessions")
  transactions       PaymentTransaction[]
  auditLogs          AuditLog[]
  accounts           Account[]
  sessions           Session[]
  mentorFields       MentorTeachingField[]
  leaderboardEntries Leaderboard[]

  @@index([email])
  @@index([googleId])
  @@index([role])
  @@index([status])
  @@index([activationCode])
  @@index([isDeleted])
}

// ==================== MENTOR PROFILE ====================

model MentorProfile {
  id String @id @default(cuid())

  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])

  // Mentor specific fields
  title           String?   // e.g., "Senior Software Engineer"
  company         String?
  experienceYears Int       @default(0)
  hourlyRate      Float     @default(0) // Suggested donation amount (VND)
  rating          Float     @default(0)
  totalReviews    Int       @default(0)
  totalSessions   Int       @default(0)
  totalEarnings   Float     @default(0) // Tổng số tiền quyên góp

  // Charity Account - Số tài khoản Thiện Nguyện App
  charityAccountNo    String?   // Số tài khoản 4 số (VD: 2000)
  charityAccountName  String?   // Tên chủ tài khoản

  // Availability
  availableHours  String?   // JSON string for weekly availability
  isAvailable     Boolean   @default(true)

  // Verification
  isVerified      Boolean   @default(false) // Đã được xác minh

  // Audit Fields
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?

  // Soft Delete
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedBy   String?

  // Versioning
  version     Int       @default(0)

  @@index([userId])
  @@index([isAvailable])
  @@index([isVerified])
  @@index([charityAccountNo])
  @@index([isDeleted])
}

// ==================== MENTEE PROFILE ====================

model MenteeProfile {
  id String @id @default(cuid())

  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])

  // Mentee specific fields
  learningGoals     String?   // JSON string for learning goals array
  preferredTopics   String?   // JSON string for preferred topics
  educationLevel    String?
  totalSessions     Int       @default(0)
  totalSpent        Float     @default(0) // Tổng số tiền đã quyên góp

  // Audit Fields
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?

  // Soft Delete
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedBy   String?

  // Versioning
  version     Int       @default(0)

  @@index([userId])
  @@index([isDeleted])
}

// ==================== TEACHING FIELD ====================

model TeachingField {
  id String @id @default(cuid())

  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?   // Icon name from lucide
  color       String?   // Hex color
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)

  // Audit Fields
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  mentors     MentorTeachingField[]

  @@index([slug])
  @@index([isActive])
}

// ==================== MENTOR TEACHING FIELD ====================

model MentorTeachingField {
  id String @id @default(cuid())

  mentorId        String
  mentor          User            @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  teachingFieldId String
  teachingField   TeachingField   @relation(fields: [teachingFieldId], references: [id], onDelete: Cascade)

  // Experience level in this field
  experienceLevel String?   // BEGINNER, INTERMEDIATE, EXPERT
  yearsOfExperience Int?

  createdAt   DateTime  @default(now())

  @@unique([mentorId, teachingFieldId])
  @@index([mentorId])
  @@index([teachingFieldId])
}

// ==================== SESSION MENTORING ====================

model SessionMentoring {
  id String @id @default(cuid())

  // Relations
  mentorId    String
  mentor      User       @relation("MentorSessions", fields: [mentorId], references: [id])
  menteeId    String
  mentee      User       @relation("MenteeSessions", fields: [menteeId], references: [id])

  // Session Details
  title         String
  description   String?
  teachingFieldId String?  // Lĩnh vực giảng dạy

  // Schedule
  scheduledAt   DateTime
  duration      Int        @default(60) // Duration in minutes
  endedAt       DateTime?  // Thời gian kết thúc thực tế

  // Meeting
  meetingLink   String?    // Google Meet link
  meetingId     String?    // Google Meet ID

  // Payment
  amount        Float      @default(0) // Số tiền (VND)
  isPaid        Boolean    @default(false)
  paidAt        DateTime?
  paymentCode   String?    @unique // Mã thanh toán (VD: HOCPHIABCXYZ)

  // Status
  status        SessionStatus @default(PENDING_PAYMENT)

  // Notes
  mentorNotes   String?
  menteeNotes   String?

  // Rating & Review
  rating        Int?       // 1-5 stars
  review        String?
  reviewedAt    DateTime?

  // Audit Fields
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?

  // Soft Delete
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedBy   String?

  // Versioning
  version     Int       @default(0)

  @@index([mentorId])
  @@index([menteeId])
  @@index([scheduledAt])
  @@index([status])
  @@index([paymentCode])
  @@index([teachingFieldId])
  @@index([isDeleted])
}

// ==================== PAYMENT TRANSACTION ====================

model PaymentTransaction {
  id String @id @default(cuid())

  // Relations
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  sessionId   String?    // Optional: linked to a mentoring session

  // Transaction Type
  type        TransactionType

  // Transaction Details
  amount        Float
  currency      String     @default("VND")

  // Payment Code (for verification)
  paymentCode   String?    @unique // VD: KICHHOATABCXYZ, HOCPHIBCDEFG

  // Charity Account Info
  charityAccountNo    String?   // Số tài khoản Thiện Nguyện App

  // External Transaction Info (from Thiện Nguyện App API)
  externalTransactionId String?   // ID from Thiện Nguyện App
  externalRefId        String?   // Ref ID (FTxxxxx)
  transactionTime      DateTime? // Thời gian giao dịch từ API
  senderName           String?   // Tên người chuyển
  narrative            String?   // Nội dung chuyển khoản

  // Status
  status        TransactionStatus @default(PENDING)

  // Verification
  verifiedAt    DateTime?
  verifiedBy    String?    // System or Admin who verified

  // Audit Fields
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?

  // Soft Delete
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedBy   String?

  // Versioning
  version     Int       @default(0)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([paymentCode])
  @@index([createdAt])
  @@index([isDeleted])
}

// ==================== LEADERBOARD ====================

model Leaderboard {
  id String @id @default(cuid())

  userId      String
  user        User       @relation(fields: [userId], references: [id])

  // Period
  period      String     // Format: YYYY-MM for monthly
  periodType  String     // MONTHLY, ALL_TIME

  // Type
  boardType   String     // MENTOR_TOP_EARNINGS, MENTEE_TOP_SESSIONS, etc.

  // Stats
  rank        Int
  score       Float      // Earnings for mentor, sessions for mentee
  sessionsCount Int      @default(0)

  // Audit Fields
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, period, periodType, boardType])
  @@index([period])
  @@index([boardType])
  @@index([rank])
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id String @id @default(cuid())

  // Relations
  userId      String?
  user        User?      @relation(fields: [userId], references: [id])

  // Audit Details
  action      String
  entityType  String
  entityId    String
  oldValues   String?
  newValues   String?
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime   @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

// ==================== ACCOUNT (NextAuth) ====================

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ==================== SESSION (NextAuth) ====================

model Session {
  id           String  @id @default(cuid())
  sessionToken String  @unique
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([sessionToken])
}

// ==================== VERIFICATION TOKEN (NextAuth) ====================

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  createdAt DateTime @default(now())

  @@unique([identifier, token])
}
